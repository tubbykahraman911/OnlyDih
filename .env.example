# OnlyDihs environment reference. Do not put real secrets in this file.

# =========================
# Local web env: apps/web/.env.local
# =========================
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080"

# =========================
# Production web env: Vercel
# =========================
# NEXT_PUBLIC_API_BASE_URL="https://YOUR_API_DOMAIN"

# =========================
# Local API env: apps/api/.env
# =========================
NODE_ENV="development"
PORT=8080
HOST="127.0.0.1"
APP_BASE_URL="http://localhost:3000"
WEB_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/onlydihs?schema=public"
REDIS_URL="redis://localhost:6379"
SESSION_SECRET="replace-with-at-least-24-random-characters"
VERIFICATION_PROVIDER="placeholder"
VERIFICATION_PROVIDER_API_KEY="placeholder"
VERIFICATION_WEBHOOK_SECRET="replace-with-webhook-secret"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_IDENTITY_RESTRICTED_KEY=""
STRIPE_IDENTITY_RETURN_URL="http://127.0.0.1:3000/verification"
AI_PROVIDER="xai"
XAI_API_KEY=""
XAI_MODEL="grok-4.3"
RAW_UPLOAD_RETENTION_HOURS=24

# Optional locally. In production these are required for private uploads.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# =========================
# Production API env: Railway or Render
# =========================
# NODE_ENV="production"
# PORT=8080
# DATABASE_URL="postgresql://..."
# REDIS_URL="redis://..."
# SESSION_SECRET="replace-with-strong-random-secret"
# APP_BASE_URL="https://YOUR_WEB_DOMAIN"
# WEB_ORIGINS="https://YOUR_WEB_DOMAIN"
# VERIFICATION_PROVIDER="stripe"
# STRIPE_SECRET_KEY="sk_test_or_live_..."
# STRIPE_IDENTITY_RESTRICTED_KEY="rk_test_or_live_identity_only_optional"
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_IDENTITY_RETURN_URL="https://YOUR_WEB_DOMAIN/verification"
# AI_PROVIDER="xai"
# XAI_API_KEY="xai_..."
# XAI_MODEL="grok-4.3"
# S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
# S3_REGION="auto"
# S3_BUCKET="onlydihs-private"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# RAW_UPLOAD_RETENTION_HOURS=24
