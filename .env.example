# =========================
# apps/web (Next.js)
# =========================
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080"
# Optional: only needed if a future frontend Stripe.js flow is added.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# =========================
# apps/api (Express + Prisma)
# =========================
PORT=8080
HOST="127.0.0.1"
APP_BASE_URL="http://localhost:3000"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/onlydihs?schema=public"
REDIS_URL="redis://localhost:6379"

# S3-compatible private object storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="onlydihs-private"
S3_ACCESS_KEY_ID="YOUR_ACCESS_KEY"
S3_SECRET_ACCESS_KEY="YOUR_SECRET_KEY"

# Auth, verification, retention
SESSION_SECRET="replace-with-at-least-24-random-characters"

# Use "placeholder" for local dev without Stripe, or "stripe" for Stripe Identity.
VERIFICATION_PROVIDER="placeholder"

# Placeholder verification webhook secret. This is not used for Stripe webhooks.
VERIFICATION_PROVIDER_API_KEY="placeholder"
VERIFICATION_WEBHOOK_SECRET="replace-with-webhook-secret"

# Stripe Identity verification. Required when VERIFICATION_PROVIDER="stripe".
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_IDENTITY_RETURN_URL="http://127.0.0.1:3000/verification"
RAW_UPLOAD_RETENTION_HOURS=24
