# =========================
# apps/web (Next.js)
# =========================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Where your deployed API runs (including protocol + port)
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080"

# Used for PPV unlock payments in chat
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# =========================
# apps/api (Express + Prisma)
# =========================
PORT=8080

# Postgres
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sizeai?schema=public"

# Redis (optional for local MVP; recommended for SSE + rate limiting)
REDIS_URL="redis://localhost:6379"

# Supabase (service role for verifying JWTs and admin actions)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Connect onboarding redirect URLs
# Set these to HTTPS URLs in production.
STRIPE_ONBOARD_REFRESH_URL="http://localhost:3000/stripe/onboard/refresh"
STRIPE_ONBOARD_RETURN_URL="http://localhost:3000/stripe/onboard/return"

# Subscription checkout redirect URLs
STRIPE_SUBS_SUCCESS_URL="http://localhost:3000/stripe/subscription/success"
STRIPE_SUBS_CANCEL_URL="http://localhost:3000/stripe/subscription/cancel"

# (Optional convenience for local dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 credentials (S3-compatible)
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="sizeai-private"

# AI service base URL (FastAPI)
AI_SERVICE_URL="http://localhost:8000"

# =========================
# apps/ai-service (FastAPI)
# =========================
# Optional (we don't download models in the MVP heuristic build, but keep for future upgrades)
HF_TOKEN=""
MODEL_DIR="./models"
MAX_IMAGE_MB="8"

